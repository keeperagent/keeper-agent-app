  "build": {
    "productName": "KeeperAgent",
    "files": [
      "build/**/*",
      "dist/**/*",
      "!node_modules/hardhat",
      "!node_modules/hardhat-watcher",
      "!node_modules/@nomicfoundation",
      "!node_modules/solc"
    ],
    "extraMetadata": {
      "main": "dist/electron/main/index.js"
    },
    "directories": {
      "buildResources": "src/asset",
      "output": "release"
    },
    "win": {
      "icon": "src/asset/logo.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "src/asset/logo.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.inherit.plist",
      "notarize": true
    },
    "protocols": {
      "name": "Keeper Agent",
      "schemes": [
        "keeperagent"
      ]
    },
    "npmRebuild": false,
    "asarUnpack": [
      "node_modules/@vscode/sqlite3"
    ]
  }
}
