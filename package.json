  "scripts": {
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix --max-warnings 0",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package-mac": "electron-builder build --mac --universal --publish never",
    "package-mac-intel": "electron-builder build --mac --x64 --publish never",
    "package-mac-arm": "electron-builder build --mac --arm64 --publish never",
    "package-win": "electron-builder --win --x64 --publish never",
    "postinstall": "electron-builder install-app-deps",
    "release-win": "rm -rf release && npm run build && npm run package-win",
    "release-mac": "rm -rf release && npm run build && npm run package-mac",
    "release-mac-intel": "rm -rf release && npm run build && npm run package-mac-intel",
    "release-mac-arm": "rm -rf release && npm run build && npm run package-mac-arm"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
